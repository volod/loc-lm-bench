# loc-lm-bench environment. Copy to .env (gitignored): `cp .env.example .env`.
# `make demo-eval` / `make venv` seed .env from this file on first run, then stop so you can
# fill in HF_TOKEN and review the host defaults below. Canonical variable names: src/llb/env.py
# Active assignments below are the defaults; commented lines show optional overrides + examples.

# --- Paths ---
# Runtime data root (indexes, gold sets, MLflow store, serving artifacts, caches).
# Relative paths resolve against the project root. Generated serve/run scripts:
# $DATA_DIR/llb/serving/gpu-<tier>gb/
DATA_DIR=.data

# --- uv package linking (auto-detected; optional override) ---
# How uv places packages from its shared cache into .venv. Leave this UNSET (or set =auto) and
# the resolver decides per host: it forces `copy` only when this checkout and uv's cache are on
# different filesystems (a cross-device hardlink would fail + warn), otherwise it keeps uv's fast
# default. Set a specific mode to force it: copy | hardlink | clone | symlink.
# UV_LINK_MODE=auto

# --- Logging ---
# Set to debug, 1, or true for verbose tracebacks and DEBUG-level logs.
# LLB_LOG=debug

# --- Hugging Face ---
# Token for gated model/dataset downloads (MamayLM, Gemma 4, ingest-uk-squad, prep-models).
HF_TOKEN=

# --- Frontier LLM prep (litellm) ---
# Leave blank until you run prep utilities that call hosted frontier models.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Candidate inference endpoints ---
# Used by RunConfig, eval clients, and generated serve scripts. LLAMACPP_HOST is the
# `llama-server` endpoint (the GGUF backend); its port is parsed from this URL.
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000
LLAMACPP_HOST=http://localhost:8080
# OpenAI-compatible base URL overrides for legacy judge_model prefixes:
# OLLAMA_API_BASE=http://localhost:11434/v1
# HOSTED_VLLM_API_BASE=http://localhost:8000/v1

# --- vLLM subprocess ---
# Consumer GPUs (RTX 40xx/50xx): avoid flashinfer sampler JIT failures at startup.
# Set to 1 only on hosts where the flashinfer kernel builds cleanly.
VLLM_USE_FLASHINFER_SAMPLER=0

# --- Local LLM judge (optional; off unless JUDGE_MODEL is set) ---
# The judge stays demoted until Ukrainian calibration passes (Spearman rho >= 0.6); objective
# correctness ranks models on its own by default. See docs/guides/judge-experiments.md.
#
# JUDGE_MODEL: litellm route for the judge, served by a LOCAL OpenAI-compatible endpoint (no
# data egress). Unset -> no judge runs. Sizing guidance (mirrors the Makefile JUDGE_MODEL knob):
#   12 GB GPU: ollama_chat/gemma-4-e4b-it
#   16 GB GPU: hosted_vllm/google/gemma-4-12B-it-qat-w4a16-ct
#   32 GB GPU: hosted_vllm/google/gemma-4-12B-it
# JUDGE_MODEL=hosted_vllm/google/gemma-4-12B-it-qat-w4a16-ct
#
# Judge endpoint (OpenAI-compatible; no cloud egress). DEEPEVAL_JUDGE_API_KEY is a placeholder
# for local servers that require an Authorization header. The Makefile exposes the same endpoint
# as JUDGE_BASE_URL= / --judge-base-url for the calibration + judge-experiment recipes.
DEEPEVAL_JUDGE_BASE_URL=http://localhost:8000/v1
DEEPEVAL_JUDGE_API_KEY=local
DEEPEVAL_TELEMETRY_OPT_OUT=YES

# --- MLflow UI ---
# Host and port for `make mlflow` (experiment comparison UI).
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000

# --- vLLM build (optional; `make build-vllm`) ---
# Registry version or wheel URL for prebuilt installs:
# VLLM_SPEC=vllm
# Clean git checkout root for a from-source wheel (see docs/guides/vllm-backend.md):
# VLLM_SOURCE_DIR=
# Requirements file for source-build deps (defaults to checkout requirements/build.txt):
# VLLM_BUILD_REQUIREMENTS=
# Force rebuilding the cached checkout wheel:
# REBUILD_VLLM_WHEEL=0
# Parallel compile jobs (normally set by scripts/build_vllm.sh via max_jobs()):
# MAX_JOBS=
