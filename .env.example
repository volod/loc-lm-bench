# loc-lm-bench environment. Copy to .env (gitignored): `cp .env.example .env`.
# `make venv` does this for you if .env is missing.

# Runtime data root (indexes, gold sets, MLflow store, serving artifacts, caches).
# Relative paths resolve against the project root, not the current directory.
# Generated serve/run scripts: $DATA_DIR/llb/serving/gpu-<tier>gb/
DATA_DIR=.data

# Frontier-API keys for the LLM judge + prep utils (litellm). Leave blank until needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Hugging Face token for gated model/dataset downloads.
# Required for MamayLM, Gemma 4, and `make prep-models` / `make ingest-uk-squad` on gated repos.
HF_TOKEN=

# Local inference endpoints (override if non-standard).
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000

# vLLM startup (consumer GPUs: RTX 40xx/50xx). Avoid flashinfer sampler JIT failures.
# Generated serve_*.sh scripts and llb honor this; default 0 when unset.
# Set to 1 only on hosts where the flashinfer kernel builds cleanly.
VLLM_USE_FLASHINFER_SAMPLER=0
