# loc-lm-bench environment. Copy to .env (gitignored): `cp .env.example .env`.
# `make venv` does this for you if .env is missing.
# Canonical variable names: src/llb/env.py

# --- Paths ---
# Runtime data root (indexes, gold sets, MLflow store, serving artifacts, caches).
# Relative paths resolve against the project root. Generated serve/run scripts:
# $DATA_DIR/llb/serving/gpu-<tier>gb/
DATA_DIR=.data

# --- Logging ---
# Set to debug, 1, or true for verbose tracebacks and DEBUG-level logs.
# LLB_LOG=debug

# --- Hugging Face ---
# Token for gated model/dataset downloads (MamayLM, Gemma 4, ingest-uk-squad, prep-models).
HF_TOKEN=

# --- Frontier LLM prep (litellm) ---
# Leave blank until you run prep utilities that call hosted frontier models.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Candidate inference endpoints ---
# Used by RunConfig, eval clients, and generated serve scripts.
OLLAMA_HOST=http://localhost:11434
VLLM_HOST=http://localhost:8000
# OpenAI-compatible base URL overrides for legacy judge_model prefixes:
# OLLAMA_API_BASE=http://localhost:11434/v1
# HOSTED_VLLM_API_BASE=http://localhost:8000/v1

# --- vLLM subprocess ---
# Consumer GPUs (RTX 40xx/50xx): avoid flashinfer sampler JIT failures at startup.
# Set to 1 only on hosts where the flashinfer kernel builds cleanly.
VLLM_USE_FLASHINFER_SAMPLER=0

# --- Local DeepEval judge ---
# OpenAI-compatible endpoint for the gated Ukrainian G-Eval judge (no cloud egress).
# API key is a placeholder for local servers that require the Authorization header.
DEEPEVAL_JUDGE_BASE_URL=http://localhost:8000/v1
DEEPEVAL_JUDGE_API_KEY=local
DEEPEVAL_TELEMETRY_OPT_OUT=YES

# --- MLflow UI ---
# Host and port for `make mlflow` (experiment comparison UI).
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000

# --- vLLM build (optional; `make build-vllm`) ---
# Registry version or wheel URL for prebuilt installs:
# VLLM_SPEC=vllm
# Clean git checkout root for a from-source wheel (see docs/guides/vllm-backend.md):
# VLLM_SOURCE_DIR=
# Requirements file for source-build deps (defaults to checkout requirements/build.txt):
# VLLM_BUILD_REQUIREMENTS=
# Force rebuilding the cached checkout wheel:
# REBUILD_VLLM_WHEEL=0
# Parallel compile jobs (normally set by scripts/build_vllm.sh via max_jobs()):
# MAX_JOBS=
