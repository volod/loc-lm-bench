# loc-lm-bench environment. Copy to .env (gitignored): `cp .env.example .env`.
# `make venv` does this for you if .env is missing.

# Runtime data root (indexes, gold sets, MLflow store, caches). Relative paths
# resolve against the project root, not the current directory.
DATA_DIR=.data

# Frontier-API keys for the LLM judge + prep utils (litellm). Leave blank until needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Hugging Face token for gated model/dataset downloads (optional).
HF_TOKEN=

# Local inference endpoint defaults (override if non-standard).
OLLAMA_HOST=http://localhost:11434
